Instance.new("UICorner", button)


local farming = false


local function tpEggs(root)

	local function tpToMe(obj)

		if obj:IsA("BasePart") then
			obj.CFrame = root.CFrame

		elseif obj:IsA("Model") then
			local part = obj:FindFirstChildWhichIsA("BasePart")
			if part then
				part.CFrame = root.CFrame
			end
		end
	end


	for _, v in pairs(workspace:GetChildren()) do

		if v.Name == "CandyEgg" then
			for _, egg in pairs(v:GetChildren()) do
				tpToMe(egg)
			end
		end

		if tostring(v):lower():find("egg")
		or tostring(v):lower():find("candy")
		or tostring(v):lower():find("collect") then
			tpToMe(v)
		end

	end

end


local function tpZone(root)

	local zone = workspace
	:WaitForChild("Interiors")
	:WaitForChild("MainMap!Sugarfest2026")
	:WaitForChild("Event")
	:WaitForChild("Sugarfest")
	:WaitForChild("ChocolateRiver")
	:WaitForChild("CollectionZone")
	:WaitForChild("ZoneModel")

	local part = zone:FindFirstChildWhichIsA("BasePart")

	if part then
		root.CFrame = part.CFrame
	end

end


button.MouseButton1Click:Connect(function()

	farming = not farming

	if farming then

		button.Text = "ON"

		task.spawn(function()

			while farming do

				local char = player.Character or player.CharacterAdded:Wait()
				local root = char:WaitForChild("HumanoidRootPart")

				tpEggs(root)
				tpZone(root)

				task.wait(0.5)

			end

		end)

	else

		button.Text = "OFF"

	end

end)
